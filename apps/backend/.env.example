NODE_ENV=development
PORT=4000
APP_URL=http://localhost:3000
SESSION_SECRET=change-me-to-a-random-32-plus-character-string
DEV_AUTH_PASSWORD=changeme

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=price_insight
MYSQL_PASSWORD=change_me
MYSQL_DATABASE=price_insight

# Public base URL Shopify/DataForSEO webhooks are verified against
WEBHOOK_HOST=http://localhost:4000

DATAFORSEO_LOGIN=your_dataforseo_login
DATAFORSEO_PASSWORD=your_dataforseo_password
DATAFORSEO_WEBHOOK_SECRET=generate_a_strong_random_secret

OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4.1-mini

# Your store name — competitor results matching this name are excluded from search results
OWN_STORE_NAME=Acme Outdoors

# Shopify (client credentials flow)
SHOPIFY_TOKEN_URL=https://your-store.myshopify.com/admin/oauth/access_token
SHOPIFY_PRODUCTS_URL=https://your-store.myshopify.com/admin/api/2024-01/products.json
SHOPIFY_ORDERS_URL=https://your-store.myshopify.com/admin/api/2024-01/orders.json
SHOPIFY_CLIENT_ID=your_shopify_api_key
SHOPIFY_CLIENT_SECRET=your_shopify_api_secret_key
# GraphQL URL is derived automatically from SHOPIFY_PRODUCTS_URL — no extra var needed.

# Cloud Tasks / Cloud Scheduler -> order-worker (only needed in deployed environments)
# CLOUD_TASKS_PROJECT=your-gcp-project
# CLOUD_TASKS_LOCATION=australia-southeast1
# CLOUD_TASKS_QUEUE=order-sync
# ORDER_WORKER_URL=https://order-worker-xxxxx.run.app
# INTERNAL_OIDC_SERVICE_ACCOUNT=price-insight-invoker@your-gcp-project.iam.gserviceaccount.com

# Cloud Tasks -> self, for async DataForSEO pingback processing (optional — processed inline when unset)
# BACKEND_CLOUD_RUN_URL=https://backend-xxxxx.run.app
